OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LECTUREFORGE_TRANSCRIPT_PROVIDER=auto
# Optional comma-separated override. Default auto strategy uses free YouTube captions,
# then yt-dlp captions, and only then optional OpenAI audio transcription.
LECTUREFORGE_TRANSCRIPT_STRATEGY=
LECTUREFORGE_ENABLE_SUPADATA=false
LECTUREFORGE_PREFER_SUPADATA=false
LECTUREFORGE_ALLOW_HOSTED_AUDIO_TRANSCRIPTION=false
# Optional deployment escape hatches for YouTube cloud-IP blocks.
# Use a rotating residential proxy URL if Render/cloud IPs are blocked.
LECTUREFORGE_YOUTUBE_PROXY_URL=
# Optional Netscape cookies.txt support for yt-dlp. Prefer B64 for Render env vars:
# base64 -i cookies.txt | pbcopy
LECTUREFORGE_YOUTUBE_COOKIES_B64=
LECTUREFORGE_YOUTUBE_COOKIES_PATH=
YTDLP_COMMAND_TIMEOUT_SECONDS=15
OPENAI_AUDIO_UPLOAD_LIMIT_BYTES=25165824
OPENAI_TRANSCRIPTION_MAX_RETRIES=3
OPENAI_TRANSCRIPTION_RETRY_BASE_SECONDS=2
LECTUREFORGE_DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# LLM provider selection:
# auto = use Ollama when a local generation model is installed, otherwise OpenAI.
# ollama = require local Ollama.
# openai = always use OpenAI.
LECTUREFORGE_LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_HEALTH_TIMEOUT_SECONDS=8
OLLAMA_NUM_PREDICT=4096

SUPADATA_API_KEY=
SUPADATA_TRANSCRIPT_MODE=auto
SUPADATA_CHUNK_SIZE=1000
SUPADATA_JOB_TIMEOUT_SECONDS=120
SUPADATA_JOB_POLL_INTERVAL_SECONDS=1

# Comma-separated origins for browser clients.
# Use your deployed frontend domain in production.
LECTUREFORGE_CORS_ORIGINS=http://localhost:5173,https://localhost,capacitor://localhost

# Set to true only for local debugging.
LECTUREFORGE_ENABLE_DEBUG_ENDPOINTS=false
