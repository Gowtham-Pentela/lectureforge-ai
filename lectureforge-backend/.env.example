OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LECTUREFORGE_TRANSCRIPT_PROVIDER=auto
LECTUREFORGE_DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# LLM provider selection:
# auto = use Ollama when a local generation model is installed, otherwise OpenAI.
# ollama = require local Ollama.
# openai = always use OpenAI.
LECTUREFORGE_LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_HEALTH_TIMEOUT_SECONDS=8
OLLAMA_NUM_PREDICT=4096

SUPADATA_API_KEY=YOUR_API_KEY_HERE
SUPADATA_TRANSCRIPT_MODE=auto
SUPADATA_CHUNK_SIZE=1000
SUPADATA_JOB_TIMEOUT_SECONDS=120
SUPADATA_JOB_POLL_INTERVAL_SECONDS=1

# Comma-separated origins for browser clients.
# Use your deployed frontend domain in production.
LECTUREFORGE_CORS_ORIGINS=http://localhost:5173,https://localhost,capacitor://localhost

# Set to true only for local debugging.
LECTUREFORGE_ENABLE_DEBUG_ENDPOINTS=false
